tower = group(
move(0,4,0,intersection(repeat(2,2,2,cube(1,1,1)),difference(cube(2,2,2),cube(4,2,4))))

,difference(move(0,1,0,cube(0.5,1.5,5)),difference(cube(3,9,3),cube(4,8,4)))
)

gate = difference(group(move(2,0.8,0,cube(1,1,4)),move(-2,0.8,0,cube(1,1,4))),move(0,-1.5,0,difference(move(0,-1.1,0,cube(1.5,3,4)),cube(4,5,3))))


castle = group (
gate,

move(4,0,0,tower),

move(-4,0,0,tower)
)

paint(#ef2302,castle)
