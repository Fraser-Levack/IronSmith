// Variables for our sword
blade_w = 2
blade_h = 20
blade_d = 0.5

guard_w = 8
guard_h = 2
guard_d = 1

handle_w = 1.5
handle_h = 6
handle_d = 1.5

// The engine will now successfully save this massive tree to memory!
sword = group(
    move(0, 10, 0, cube(blade_w, blade_h, blade_d)), 
    move(0, 0, 0, cube(guard_w, guard_h, guard_d)),  
    move(0, -4, 0, cube(handle_w, handle_h, handle_d))
)

// Draw the variable!
move(0, -5, 0, rotateZ(45, sword))

// You can even draw a second sword easily now!
move(20, 0, 0, rotateZ(-45, sword))